# =============================================================================
# Game Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
# =============================================================================

# ---- Server ----
SERVER_PORT=8000
SERVER_HOST=0.0.0.0
SERVER_MODE=release

# ---- PostgreSQL ----
# Full connection string used by both the Go app and the migration runner.
# In docker-compose the hostname is "db" (the service name).
DATABASE_URL=postgresql://game:changeme@db:5432/game_platform?sslmode=disable

# docker-compose DB service credentials (must match DATABASE_URL):
POSTGRES_PASSWORD=changeme

# ---- Redis ----
# In docker-compose the hostname is "redis" (the service name).
REDIS_URL=redis:6379

# ---- S3 (external) ----
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=game-platform
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# ---- LiveKit (external) ----
LIVEKIT_HOST=https://livekit.example.com
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ---- Corporate Portal (SSO + API) ----
PORTAL_API_URL=https://portal.example.com/api
PORTAL_API_KEY=your-portal-api-key
OIDC_JWKS_URL=https://portal.example.com/.well-known/jwks.json

# ---- JWT ----
JWT_SECRET=change-this-to-a-random-secret-in-production

# ---- Rate Limiting ----
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---- CORS ----
# Comma-separated list of allowed origins (optional)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
