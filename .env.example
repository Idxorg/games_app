# Сервер
PORT=8000
HOST=0.0.0.0

# База данных
DATABASE_URL=postgresql://game:game123@localhost:5432/game_platform?sslmode=disable

# Redis
REDIS_URL=localhost:6379

# S3 (внешний)
S3_ENDPOINT=https://s3.yakbson.digital
S3_BUCKET=yakbson-games
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# LiveKit (внешний)
LIVEKIT_URL=https://livekit.yakbson.digital
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Корп портал (SSO + API)
PORTAL_API_URL=https://portal.yakbson.digital/api
PORTAL_API_KEY=your-portal-api-key
OIDC_JWKS_URL=https://portal.yakbson.digital/.well-known/jwks.json

# JWT (для внутренних сессий)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
